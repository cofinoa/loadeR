netcdf test_multidimrlonrlat {
dimensions:
    runtime = 2 ;
    member = 5 ;
    time = 4 ;
    lev = 1 ;
    rlon = 2 ;
    rlat = 2 ;

variables:
    double runtime(runtime) ;
        runtime:units = "hours since 2000-01-01 00:00:00" ;
        runtime:long_name = "model initialization time" ;
        runtime:_CoordinateAxisType = "RunTime" ;

    double member(member) ;
        member:long_name = "ensemble member" ;
        member:units = "1" ;
        member:_CoordinateAxisType = "Ensemble" ;

    double time(time) ;
        time:units = "hours since 2000-01-01 00:00:00" ;
        time:long_name = "forecast time" ;
        time:_CoordinateAxisType = "Time" ;

    double lev(lev) ;
        lev:units = "hPa" ;
        lev:long_name = "pressure level" ;
        lev:_CoordinateAxisType = "GeoZ" ;
        lev:positive = "down" ;

    double rlon(rlon);
        rlon:standard_name = "grid_longitude";
        rlon:long_name = "longitude in rotated pole grid";
        rlon:units = "degrees";
        rlon:axis = "X";

    double rlat(rlat);
        rlat:standard_name = "grid_latitude";
        rlat:long_name = "latitude in rotated pole grid";
        rlat:units = "degrees";
        rlat:axis = "Y";

    double lon(rlat, rlon);
        lon:standard_name = "longitude";
        lon:long_name = "longitude";
        lon:units = "degrees_east";

    double lat(rlat, rlon);
        lat:standard_name = "latitude";
        lat:long_name = "latitude";
        lat:units = "degrees_north";

    double tas(runtime, member, time, lev, rlat, rlon) ;
        tas:long_name = "air temperature" ;
        tas:standard_name = "air_temperature" ;
        tas:units = "K" ;
        tas:missing_value = -9999.0 ;
        tas:coordinates = "runtime member time lev lat lon" ;

data:
 runtime = 0, 24 ;
 member = 1, 2, 3, 4, 5 ;
 time = 0, 6, 12, 18 ;
 lev = 850 ;

 rlat = 0.0, 1.0 ;
 rlon = 0.0, 1.0 ;

 lat =
   40.0, 40.1,
   41.0, 41.1 ;
 lon =
   -3.5, -3.4,
   -3.6, -3.5 ;

 tas =
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,
  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,
  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343,
  344,345,346,347,348,349,350,351,
  352,353,354,355,356,357,358,359,
  360,361,362,363,364,365,366,367,
  368,369,370,371,372,373,374,375,
  
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,
  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,
  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343 ; 
}
