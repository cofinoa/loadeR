netcdf test_runtime {
dimensions:
    run = 3 ;
    time = 12 ;
    member = 1 ;
    lev = 1 ;
    lat = 2 ;
    lon = 2 ;
    
variables:
    double time(run, time) ;
      time:long_name = "Forecast time for ForecastModelRunCollection" ;
      time:standard_name = "time" ;
      time:units = "hours since 1981-01-01T00:00:00Z" ;
      time:missing_value = NaN ;
      time:_CoordinateAxisType = "Time" ;

    float lat(lat) ;
      lat:units = "degrees_north" ;
      lat:long_name = "" ;
      lat:_CoordinateAxisType = "Lat" ;
      lat:standard_name = "latitude" ;

    float lon(lon) ;
      lon:units = "degrees_east" ;
      lon:long_name = "" ;
      lon:_CoordinateAxisType = "Lon" ;
      lon:standard_name = "longitude" ;

    double run(run) ;
      run:long_name = "Run time for ForecastModelRunCollection" ;
      run:standard_name = "forecast_reference_time" ;
      run:units = "hours since 1981-01-01T00:00:00Z" ;
      run:_CoordinateAxisType = "RunTime" ;

    double member(member) ;
        member:long_name = "ensemble member" ;
        member:units = "1" ;
        member:_CoordinateAxisType = "Ensemble" ;

    double lev(lev) ;
        lev:units = "hPa" ;
        lev:long_name = "pressure level" ;
        lev:_CoordinateAxisType = "GeoZ" ;
        lev:positive = "down" ;
    
    double tas(run, time, member, lev, lat, lon) ;
        tas:standard_name = "air_temperature" ;
        tas:long_name = "2m temperature" ;
        tas:units = "K" ;
        tas:coordinates = "run time member lev lat lon" ;

data:
 run = -8784, 0, 8760 ; // Start of 1980, 1981, 1982 (in hours)

 time =
  // 1980
  -8784, -8508, -8208, -7920, -7616, -7304, -6992, -6712, -6400, -6096, -5792, -5480,
  // 1981
  0, 744, 1416, 2160, 2856, 3552, 4320, 5016, 5736, 6456, 7152, 7848,
  // 1982
  8760, 9504, 10248, 10944, 11664, 12384, 13104, 13848, 14568, 15288, 16008, 16704 ;

 lat = 40.0, 41.0 ;
 lon = -3.5, -3.6 ;
 
 member = 1;

 lev = 850;

 tas =
  // 3 runs × 12 months × 2 lats × 2 lons = 144 values 
  280,281,282,283,284,285,286,287,288,289,290,291,
  292,293,294,295,296,297,298,299,300,301,302,303,
  304,305,306,307,308,309,310,311,312,313,314,315,
  316,317,318,319,320,321,322,323,324,325,326,327,
  328,329,330,331,332,333,334,335,336,337,338,339,
  340,341,342,343,344,345,346,347,348,349,350,351,
  352,353,354,355,356,357,358,359,360,361,362,363,
  364,365,366,367,368,369,370,371,372,373,374,375,
  376,377,378,379,380,381,382,383,384,385,386,387,
  388,389,390,391,392,393,394,395,396,397,398,399,
  400,401,402,403,404,405,406,407,408,409,410,411,
  412,413,414,415,416,417,418,419,420,421,422,423 ;
}
