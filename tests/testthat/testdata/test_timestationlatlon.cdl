netcdf test_timestationlatlon {
dimensions:
    time = 2 ;
    station_id = 2 ;
    lat = 2 ;
    lon = 2 ;

variables:
    double time(time) ;
        time:standard_name = "time" ;
        time:units = "days since 2000-01-01 00:00:00" ;
        time:calendar = "gregorian" ;
        time:_CoordinateAxisType = "Time" ;

    int station_id(station_id) ;
        station_id:standard_name = "station_id" ;
        station_id:units = "1" ;

    double lat(lat) ;
        lat:standard_name = "latitude" ;
        lat:units = "degrees_north" ;
        lat:_CoordinateAxisType = "Lat" ;

    double lon(lon) ;
        lon:standard_name = "longitude" ;
        lon:units = "degrees_east" ;
        lon:_CoordinateAxisType = "Lon" ;

    double tas(time, station_id, lat, lon) ;
        tas:long_name = "2m temperature" ;
        tas:standard_name = "air_temperature" ;
        tas:units = "K" ;

data:
 time = 0, 1 ;
 station_id = 1, 2 ;
 lat = 40.0, 41.0 ;
 lon = -3.5, -3.6 ;
 tas = 
   285.0, 286.0, 287.0, 288.0,
   289.0, 290.0, 291.0, 292.0,
   293.0, 294.0, 295.0, 296.0,
   297.0, 298.0, 299.0, 300.0 ;
}
