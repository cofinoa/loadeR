netcdf test_runtime_subdaily {
dimensions:
    run = 3 ;
    time = 24 ;
    lat = 2 ;
    lon = 2 ;

variables:
    double run(run) ;
        run:long_name = "Run time for ForecastModelRunCollection" ;
        run:standard_name = "forecast_reference_time" ;
        run:units = "hours since 1980-01-01 00:00:00" ;
        run:_CoordinateAxisType = "RunTime" ;

    double time(run, time) ;
        time:long_name = "Forecast time for ForecastModelRunCollection" ;
        time:standard_name = "time" ;
        time:units = "hours since 1980-01-01 00:00:00" ;
        time:_CoordinateAxisType = "Time" ;

    float lat(lat) ;
        lat:units = "degrees_north" ;
        lat:standard_name = "latitude" ;
        lat:_CoordinateAxisType = "Lat" ;

    float lon(lon) ;
        lon:units = "degrees_east" ;
        lon:standard_name = "longitude" ;
        lon:_CoordinateAxisType = "Lon" ;

    double tas(run, time, lat, lon) ;
        tas:standard_name = "air_temperature" ;
        tas:long_name = "2m temperature" ;
        tas:units = "K" ;
        tas:coordinates = "run time lat lon" ;

data:
 run = 0, 8760, 17520 ; // 1980, 1981, 1982 (in hours since 1980-01-01)

 time =
   // Time values represent forecast steps in hours after each run
   0, 1, 2, 3, 4, 5, 6, 7,
   24, 25, 26, 27, 28, 29, 30, 31,
   48, 49, 50, 51, 52, 53, 54, 55,

   8760, 8761, 8762, 8763, 8764, 8765, 8766, 8767,
   8784, 8785, 8786, 8787, 8788, 8789, 8790, 8791,
   8808, 8809, 8810, 8811, 8812, 8813, 8814, 8815,

   17520, 17521, 17522, 17523, 17524, 17525, 17526, 17527,
   17544, 17545, 17546, 17547, 17548, 17549, 17550, 17551,
   17568, 17569, 17570, 17571, 17572, 17573, 17574, 17575 ;

 lat = 40.0, 41.0 ;
 lon = -3.5, -3.6 ;

 tas =
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,

  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,

  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343,
  344,345,346,347,348,349,350,351,
  
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,

  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,

  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343,
  344,345,346,347,348,349,350,351,
  
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,

  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,

  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343,
  344,345,346,347,348,349,350,351,
  
  280,281,282,283,284,285,286,287,
  288,289,290,291,292,293,294,295,
  296,297,298,299,300,301,302,303,

  304,305,306,307,308,309,310,311,
  312,313,314,315,316,317,318,319,
  320,321,322,323,324,325,326,327,

  328,329,330,331,332,333,334,335,
  336,337,338,339,340,341,342,343,
  344,345,346,347,348,349,350,351 ;
}
