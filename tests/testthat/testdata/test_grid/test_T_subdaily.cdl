netcdf test_T_subdaily {
dimensions:
    time = 8 ;
    rlat = 1 ;
    rlon = 1 ;

variables:
    double time(time) ;
		time:long_name = "Time variable" ;
		time:units = "days since 1950-01-01 00:00:00" ;
		time:_CoordinateAxisType = "Time" ;
	double lat(rlat) ;
		lat:standard_name = "latitude" ;
		lat:long_name = "latitude" ;
		lat:units = "degrees north" ;
		lat:_CoordinateAxisType = "Lat" ;
	double lon(rlon) ;
		lon:standard_name = "longitude" ;
		lon:long_name = "longitude" ;
		lon:units = "degrees east" ;
		lon:_CoordinateAxisType = "Lon" ;
	float T(time, rlon, rlat) ;
		T:standard_name = "temperature" ;
		T:long_name = "Temperature" ;
		T:units = "K" ;
		T:missing_value = -9999.f ;

data:
	// 11323 corresponds to 1980-12-31; values every 6 hours until 1981-01-01 18:00
    time = 11323, 11323.25, 11323.5, 11323.75, 11324, 11324.25, 11324.5, 11324.75 ;
    lat = 40.0 ;
    lon = -3.5 ;
    T = 290, 291, 292, 293, 294, 295, 296, 297 ;
}
